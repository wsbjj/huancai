# API 服务
HOST=0.0.0.0
PORT=3001
UPLOAD_MAX_FILE_SIZE_MB=10

# 在网关请求体中把本地上传文件作为 data URL 一并发送。
AI_GATEWAY_INCLUDE_DATA_URLS=true

# 外部 AI HTTP 网关配置
# 重要：必须填写完整的 JSON API 接口地址，不能只填域名根地址。
# 示例（通过兼容 Apifox 的网关调用 Nano Banana / Gemini 原生接口）：
# https://your-gateway.com/v1beta/models/gemini-2.5-flash-image:generateContent
AI_GATEWAY_HTTP_URL=
# 可选：用英文逗号分隔的接口地址列表。
# 如果 AI_GATEWAY_HTTP_URL 为空，则这里的第一个 URL 会作为主接口地址。
AI_GATEWAY_HTTP_URLS=
# 可选：额外的备用接口地址，用英文逗号分隔。
AI_GATEWAY_HTTP_URL_FALLBACKS=
AI_GATEWAY_HTTP_METHOD=POST
AI_GATEWAY_HTTP_TIMEOUT_MS=120000

# 请求体模式：
# - generic：发送幻裁自定义 JSON（request/moduleId/images/options/meta）
# - openai-images：发送兼容 OpenAI 的图像生成 JSON
# - openai-images-edit：发送 model + prompt + image_urls（主图/参考图）
# - nano-banana-generate-content：发送 Nano Banana / Gemini generateContent JSON，并使用 inlineData 图片
# - gemini-image-generation-native：发送 Gemini Image Generation Native JSON，使用纯文本 prompt 生成图
# - fal-nanobanana2-edit：向 /fal-ai/nano-banana/edit 发送 prompt + image_urls（主图/参考图）
AI_GATEWAY_HTTP_PAYLOAD_MODE=generic

# 鉴权请求头配置：
# 如果设置了 API key，请求头的值会变为“<AUTH_PREFIX> <API_KEY>”
AI_GATEWAY_HTTP_API_KEY=
AI_GATEWAY_HTTP_AUTH_HEADER=Authorization
AI_GATEWAY_HTTP_AUTH_PREFIX=Bearer

# 用于从网关响应中提取生成图片 URL 的 JSON 路径。
# 按顺序尝试，使用第一个非空字符串。
AI_GATEWAY_HTTP_RESULT_URL_PATHS=generatedImageUrl,data.url,data.0.url,images.0.url,result.url,url,output.url

# 用于从网关响应中提取生成图片 base64 的 JSON 路径。
# 当没有找到 URL 路径时使用。
AI_GATEWAY_HTTP_RESULT_BASE64_PATHS=generatedImageBase64,data.b64_json,data.0.b64_json,result.base64,imageBase64,output.base64

# 当 AI_GATEWAY_HTTP_PAYLOAD_MODE=openai-images 时使用
AI_GATEWAY_OPENAI_IMAGE_MODEL=gpt-image-1
AI_GATEWAY_OPENAI_IMAGE_N=1
# 可选：1024x1024 / 1024x1536 / 1536x1024
AI_GATEWAY_OPENAI_IMAGE_SIZE=
# 可选：low / medium / high / auto（取决于服务提供方）
AI_GATEWAY_OPENAI_IMAGE_QUALITY=
# 可选：transparent / opaque
AI_GATEWAY_OPENAI_IMAGE_BACKGROUND=

# 当 AI_GATEWAY_HTTP_PAYLOAD_MODE=nano-banana-generate-content 时使用
# Nano Banana 单次请求输入图片不超过 3 张时效果最好。
AI_GATEWAY_GEMINI_MAX_INPUT_IMAGES=3

# 当 AI_GATEWAY_HTTP_PAYLOAD_MODE=gemini-image-generation-native 时使用
# 可选：1K / 2K / 4K（取决于网关支持情况）
AI_GATEWAY_GEMINI_IMAGE_SIZE=
AI_GATEWAY_GEMINI_NUMBER_OF_IMAGES=1

# 当 AI_GATEWAY_HTTP_PAYLOAD_MODE=fal-nanobanana2-edit 时使用
# 向 fal 接口请求的图片数量（1-4）
AI_GATEWAY_FAL_NUM_IMAGES=1
# 轮询间隔，单位为毫秒
AI_GATEWAY_FAL_POLL_INTERVAL_MS=1500
# 轮询超时时间，单位为毫秒
AI_GATEWAY_FAL_POLL_TIMEOUT_MS=120000
# 轮询路径模板，必须包含 {request_id}
AI_GATEWAY_FAL_RESULT_PATH_TEMPLATE=/fal-ai/auto/requests/{request_id}
